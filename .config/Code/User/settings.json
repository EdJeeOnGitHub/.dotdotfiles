{   "editor.guides.bracketPairs" : "active",
    "editor.hover.above": false,
    "vim.insertModeKeyBindings": [
        {
            "before": ["j", "j"],
            "after": ["<Esc>"]
        }
    ],
    "editor.bracketPairColorization.enabled": true,
    "editor.rulers": [80],
    "vim.foldfix": true,
    "latex-workshop.docker.image.latex": "blang/latex:ubuntu",
    "latex-workshop.view.pdf.viewer": "tab",
    "latex-workshop.latex.outDir" : "%DIR%/build",
    "git.ignoreLegacyWarning": true,
    "window.menuBarVisibility": "toggle",
    "workbench.statusBar.visible": true,
    "breadcrumbs.enabled": true,
    "terminal.integrated.commandsToSkipShell": [
        "language-julia.interrupt",
        "matlab.interrupt"
    ],
    "julia.enableTelemetry": true,
    "editor.renderControlCharacters": true,
    "editor.fontLigatures": true,
    "editor.fontFamily": "'FiraCode Nerd Font'",
    "terminal.integrated.fontFamily": " 'FiraCode Nerd Font', 'monospace', monospace, 'Droid Sans Fallback'",
    "terminal.external.linuxExec": "kitty",
    "editor.fontSize": 16,
    "r.sessionWatcher": true,
    "jupyter.askForKernelRestart": false,
    "r.bracketedPaste": true,
    "r.rterm.linux": "/usr/bin/radian",
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter.notebook.ipynb"
    },
    "vim.useSystemClipboard": true,
    "vva.trustedDomain": true,
    "editor.lineNumbers": "relative",
    "vim.enableNeovim": true,
    "vim.neovimPath": "/usr/bin/nvim",
    "julia.enableCrashReporter": false,
    "editor.inlineSuggest.enabled": true,
    "julia.execution.codeInREPL": true,
    "julia.symbolCacheDownload": true,
    "python.defaultInterpreterPath": "/usr/bin/python",
    "github.copilot.enable": {
        "quarto": false,
        "*": true,
        "yaml": false,
        "plaintext": true,
        "markdown": false
    },
    "editor.minimap.enabled": false,
    "julia.NumThreads": 10, // This get overwritten by julia.additionalArgs above
    "vim.camelCaseMotion.enable": true,
    "vim.neovimUseConfigFile": true,
    "terminal.integrated.enableMultiLinePasteWarning": false,
    "editor.acceptSuggestionOnEnter": "smart",
    "editor.hover.delay": 10,
    "r.lsp.diagnostics": false,
    "r.lsp.enabled": false,
    "r.plot.useHttpgd": true,
    "window.confirmSaveUntitledWorkspace": false,
    "github.copilot.editor.enableAutoCompletions": true,
    "jupyter.interactiveWindow.creationMode": "perFile",
    "julia.lint.run": false,
    "julia.executablePath": "/home/ed/.juliaup/bin/julia",
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "github.copilot.nextEditSuggestions.enabled": true,
    "r.rpath.linux": "/usr/bin/R",
    "claudeCode.useTerminal": true,
    "julia.useProgressFrontend": false
}